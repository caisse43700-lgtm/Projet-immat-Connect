{
  "_v": 1,
  "_doc": "Index des flux organiques d'ImmatConnect. Chaque flux répond à 7 questions : pourquoi · où visible · où stocké · qui peut agir · quel impact · comment valider · comment mémoriser.",
  "_source": "Audit ANGE — Fluidité, simplicité, intention, mémoire, action",
  "_boucle": ["intention", "repérage", "impact", "option", "validation", "action", "mémoire"],
  "_senses_mapping": {
    "entendre": "identifier l'intention",
    "voir":     "repérer les composants concernés",
    "sentir":   "comprendre le contexte et l'environnement",
    "toucher":  "mesurer l'impact avant d'agir",
    "goûter":   "tester et comparer les options"
  },

  "flows": [

    {
      "id": "FLOW-MAP-SELF-MARKER",
      "intention": "Permettre au conducteur de se repérer immédiatement sur la carte en temps réel.",
      "organes": ["Carte", "Profil"],
      "repérage": {
        "ui":    ["#map (Leaflet marker self)", "#frontCarBanner", "#invisBtn", "nav#navMap"],
        "code":  ["App.locate()", "App.loadOthers()", "App.cycleView()", "App.toggleInvisible()", "App.recenter()"],
        "state": ["S.myMarker", "S.myLat", "S.myLng", "S.driveMode", "S.mapView ('drive'|'2d')", "S.invisible"],
        "data":  ["profiles.vehicle_color", "ic_view (localStorage)", "ic_invisible (localStorage)"]
      },
      "impact": [
        "consommation GPS / batterie",
        "vie privée (mode invisible = position non partagée)",
        "couleur visible par les autres conducteurs via loadOthers()",
        "lisibilité carte (vue drive 18z vs 2d 16z)",
        "P3-001 futur : rotation selon heading GPS"
      ],
      "options": [
        "rond coloré (actuel — couleur profil via colorHex/utils.js INV-011)",
        "halo pulsant (actuel en drive mode — CSS driving class)",
        "icône directionnelle avec heading (P3-001 futur — Gardien requis)"
      ],
      "qui_peut_agir": {
        "conducteur": "locate() · cycleView() · toggleInvisible() · recenter()",
        "gardien": "modification du design du marqueur (impact visibilité + P3-001)"
      },
      "validation": "Conducteur autonome pour usage. Gardien requis pour modification du marqueur ou de la logique de localisation.",
      "mémoire": ["ic_view (localStorage — vue persistée)", "ic_invisible (localStorage)", "S.myMarker (runtime — reset à logout)"]
    },

    {
      "id": "FLOW-VEHICLE-ALERT",
      "intention": "Prévenir un conducteur identifié d'un problème visible sur son véhicule, et lui permettre de confirmer.",
      "organes": ["Signalements", "Messages", "Carte"],
      "repérage": {
        "ui":    ["panelAltet sigStep2Vehicle", "#sigVehiclePlate", ".alert-grid (vehicule)", "_actModCard (group='vehicle')", "showFloatingCard (alerte reçue)"],
        "code":  ["App.vehicleAlertQuick(label)", "App.sigStepVehicle()", "App.actConfirmAlert(id,'seen')", "broadcast 'vehicle_seen' → notifyAlert", "App.vehicleAlert(label) (overlay legacy)"],
        "state": ["S.alerts (group='vehicle')", "S.contextVehicle.plate", "S.selPlate", "a.status ('pending'|'seen'|'resolved')"],
        "data":  ["reports (plate, reason, lat, lng, category='vehicle')", "messages (receiver_id = a.sender_id, message=label)"]
      },
      "impact": [
        "message auto envoyé au conducteur cible (DB messages)",
        "alerte créée localement + persistée DB (reports)",
        "broadcast 'vehicle_seen' → retour émetteur (SESSION 19 P0-002)",
        "trust delta sur la plaque cible via signalFeedback()",
        "floating card urgent si fumée/pneu"
      ],
      "options": [
        "Pneu/roue 🔴 (urgent)",
        "Feu défaillant 💡 (urgent)",
        "Portière/coffre 🚪 (medium)",
        "Fumée/brûlé 🔥 (urgent+fire)",
        "Objet traînant ⛓️ (medium)",
        "Autre ⚠️ (info)"
      ],
      "qui_peut_agir": {
        "conducteur": "créer l'alerte (sigStep2Vehicle) + confirmer reçue (actConfirmAlert seen/resolved)",
        "destinataire": "répondre '✓ J'ai vérifié' / '✓ C'est bon' / '🙏 Merci'"
      },
      "validation": "Conducteur autonome. Plaque cible requise (sigVehiclePlate). Pas de validation Gardien.",
      "mémoire": ["S.alerts + ic_alerts (localStorage)", "S.alertHistory + ic_alert_history", "ic_resolved_remote_ids", "reports DB", "messages DB"]
    },

    {
      "id": "FLOW-ASSIST-REQUEST",
      "intention": "Demander de l'aide aux conducteurs proches et coordonner la réponse (helper + demandeur).",
      "organes": ["Signalements", "Messages", "Carte"],
      "repérage": {
        "ui":    ["panelAltet sigStep2Aide", ".alert-grid (assist)", "_actModCard (group='assist')", "#aideCallSection", "showFloatingCard ('✋ J'aide')", "badge '✋ En route · plaque'"],
        "code":  ["App.assist(type)", "App.actHelpReply(plate)", "App.actQuickReply(plate,'J\\'arrive...')", "App.cleanupAlerts() TTL", "canResolveAlert(a) — seul le créateur peut clôturer"],
        "state": ["S.alerts (group='assist', _mine=true)", "a.status ('pending'|'helper_coming')", "a._helperPlate", "a._own"],
        "data":  ["reports (category='help', TTL 30min)", "ic_alerts localStorage", "ic_offline_reports (offline buffer)"]
      },
      "impact": [
        "notification TTL si non répondue après 30min (cleanupAlerts → notifyAlert urgent)",
        "statut 'helper_coming' + _helperPlate quand J'arrive détecté",
        "bouton '🙏 Merci' affiché quand helper_coming (SESSION 19 DEC-008)",
        "trust delta vers la plaque du helper",
        "floating card urgent côté helper"
      ],
      "options": [
        "Panne 🚗 (urgent)",
        "Carburant ⛽ (medium)",
        "Batterie 🔋 (medium)",
        "Moteur ⚙️ (urgent)",
        "Incendie 🔥 (P0 — fire level)",
        "Perdu 🧭 (info)"
      ],
      "qui_peut_agir": {
        "conducteur_demandeur": "créer (assist()), résoudre (actConfirmAlert resolved — canResolveAlert uniquement)",
        "conducteur_helper": "répondre J'arrive / Je ne peux pas / Contacter / 📍 Voir sur carte",
        "organisme": "TTL cleanup (cleanupAlerts), notifications automatiques"
      },
      "validation": "Seul le créateur peut clôturer (canResolveAlert). Incendie = P0 = urgent = Gardien informé si besoin.",
      "mémoire": ["S.alerts + ic_alerts", "ic_offline_reports (offline buffer)", "a._helperPlate sur l'alerte", "reports DB (resolved_at si résolu)"]
    },

    {
      "id": "FLOW-DIRECT-MESSAGE",
