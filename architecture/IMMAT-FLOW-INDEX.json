      "organes": ["Messages", "Profil"],
      "repérage": {
        "ui":    ["panelMessages (#icMessagesPro)", "#icComposePlate + #icComposeText", ".ic-quick (quick replies)", "ic-thread (fil conversation)", "_actModCard (kind='msg')", "actCatPanel filtres 💬 Messages"],
        "code":  ["ImmatMessages.sendNew()", "ImmatMessages.quick(txt)", "ImmatMessages.reply()", "App.actQuickReply(plate,msg)", "App.pickPlate(plate)", "App.actOpenConv(plate)"],
        "state": ["S.conv (plaque active ou 'all')", "S.selPlate", "S.unreadMsgCount", "S._actMessages"],
        "data":  ["messages DB (sender_id, receiver_id, target_plate, message, status)", "ic_deleted_msgs", "ic_unread_msg_count"]
      },
      "impact": [
        "trust delta via signalFeedback() (utile +8 / réglé +3 / faux -12)",
        "actBadge non-lus incrémenté → updateActBadge()",
        "channel realtime S.chMsg actif (Supabase realtime)",
        "blocage bilatéral possible (ic_blocked INV-010)"
      ],
      "options": [
        "Composer libre (#icComposeText)",
        "Quick reply : Je m'arrête / Je vérifie / Bien reçu / 🙏 Merci (ic-quick)",
        "Répondre au fil (ic-thread icReplyText)",
        "Via card activité (actQuickReply depuis _actModCard)"
      ],
      "qui_peut_agir": {
        "conducteur": "envoyer, lire, supprimer conversation, quick reply",
        "bloqueur": "ic_blocked localStorage (INV-010) — bloque réception + envoi"
      },
      "validation": "Conducteur autonome. Blocage via ic_blocked sans validation Gardien (INV-010).",
      "mémoire": ["messages DB (persistant)", "ic_deleted_msgs localStorage", "ic_unread_msg_count localStorage", "S._actMessages runtime session"]
