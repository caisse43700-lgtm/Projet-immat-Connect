      "repérage": {
        "ui":    ["#actBadge (nav Activité)", "#actTabBadge (onglet Reçus)", "#catBadgeRoute/Vehicle/Aide (catégories)", "#resumeNewBadge + #resumeEncBadge (résumé rapide)", "#communityStatus (dot + compteurs)"],
