        "state": ["S.unreadMsgCount", "S.alerts (non-seen, non-mine, non-expired)", "S._actMessages (unread)"],
        "data":  ["ic_unread_msg_count localStorage"]
      },
      "impact": [
        "attention conducteur dirigée vers l'onglet Activité",
        "résumé rapide actMain mis à jour (Nouveaux / En cours / Traités)",
        "catégories colorées selon présence/urgence",
        "actBadge nav = alertes + messages (total activité non lue — SESSION 21)"
      ],
      "options": [
        "badge chiffre brut (≤ 99)",
        "badge formaté '99+' (badgeFmt())",
        "dot status dans card (act-mod-status-dot)"
      ],
      "qui_peut_agir": {
        "organisme": "auto-géré par schedBadge() / syncDerivedAlertUI() / setUnreadMsgCount()",
        "conducteur": "marquer lu (markRead) / tout marquer lu (markAllCatRead)",
        "gardien": "audit seulement — pas de modification directe"
